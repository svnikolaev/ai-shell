# Язык объяснений
explain_language = "ru"

# Стоп-лист (простые подстроки)
stop_list = [
    "rm -rf /",
    "rm -rf /*",
    "dd if=/dev/zero of=/dev/sd",
    ":(){ :|:& };:",
    "chmod -R 777 /",
    "> /dev/sda",
    "mv /* /dev/null",
    "mkfs",
    "fdisk",
]

# Основной бэкенд
[[backends]]
api_url = "https://gptunnel.ru/v1/chat/completions"
api_key = "shds-top-secret-key"  # использовать свой api_key
model = "gpt-4.1-nano"  # оптимально по соотношению цены, скорости и качества
timeout_secs = 60

# # План Б — локальная Ollama (установите и запустите сервер)
# [[backends]]
# api_url = "http://localhost:11434/v1/chat/completions"
# api_key = ""                       # не требуется
