# Основной бэкенд — OpenRouter (бесплатные модели)
[[backends]]
api_url = "https://openrouter.ai/api/v1/chat/completions"
api_key = "sk-or-v1-..."          # ваш ключ OpenRouter
model = "deepseek/deepseek-r1:free"  # или другая бесплатная модель
timeout_secs = 30

# План Б — локальная Ollama (установите и запустите сервер)
[[backends]]
api_url = "http://localhost:11434/v1/chat/completions"
api_key = ""                       # не требуется
model = "qwen2.5:7b"               # любая загруженная модель
timeout_secs = 10

# Язык объяснений
explain_language = "ru"

# Стоп-лист (простые подстроки)
stop_list = [
    "rm -rf /",
    "rm -rf /*",
    "dd if=/dev/zero of=/dev/sd",
    ":(){ :|:& };:",
    "chmod -R 777 /",
    "> /dev/sda",
    "mv /* /dev/null",
    "mkfs",
    "fdisk",
]
